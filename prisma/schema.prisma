generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Source {
  id               String   @id @default(cuid())
  name             String
  type             String?
  initialBalanceIqd Int     @default(0)
  isArchived       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  transactions     Transaction[]
  monthlyTemplates MonthlyExpenseTemplate[]
  templateItems    MonthlyTemplateItem[]
  debts            Debt[]
}

model Transaction {
  id          String   @id @default(cuid())
  kind        String   // EXPENSE | INCOME | DEPOSIT | WITHDRAW | TRANSFER
  amountIqd   Int
  sourceId    String
  source      Source   @relation(fields: [sourceId], references: [id])
  date        DateTime @default(now())
  note        String?
  fxEnabled   Boolean  @default(false)
  fxFromCurrency String?
  fxToCurrency  String?
  fxRate      Float?
  fxFromAmount Int?
  createdAt   DateTime @default(now())
}

model Debt {
  id         String   @id @default(cuid())
  direction  String   // RECEIVABLE | PAYABLE
  personName String
  amountIqd  Int
  status     String   @default("OPEN") // OPEN | SETTLED
  date       DateTime @default(now())
  note       String?
  sourceId   String?
  source     Source?  @relation(fields: [sourceId], references: [id])
  createdAt  DateTime @default(now())
}

model MonthlyExpenseTemplate {
  id        String   @id @default(cuid())
  name      String
  amountIqd Int
  sourceId  String
  source    Source   @relation(fields: [sourceId], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MonthlyExpenseApplyLog {
  id        String   @id @default(cuid())
  monthKey  String   // e.g. 2026-02
  appliedAt DateTime @default(now())
  @@unique([monthKey])
}

model MonthlyTemplate {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  items     MonthlyTemplateItem[]
  applyLogs MonthlyTemplateApplyLog[]
}

model MonthlyTemplateItem {
  id         String   @id @default(cuid())
  templateId String
  template   MonthlyTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name       String   // description for the transaction
  amountIqd  Int
  kind       String   // INCOME | EXPENSE
  sourceId   String
  source     Source   @relation(fields: [sourceId], references: [id])
  sortOrder  Int      @default(0)
}

model MonthlyTemplateApplyLog {
  id         String   @id @default(cuid())
  monthKey   String   // e.g. 2026-02
  templateId String
  template   MonthlyTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  appliedAt  DateTime @default(now())
  @@unique([monthKey, templateId])
}
